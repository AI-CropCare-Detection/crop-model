# Git LFS Configuration for Large Model Files
# This ensures large binary files are stored in GitHub LFS, not directly in the repo

# Model checkpoint files
*.pt filter=lfs diff=lfs merge=lfs -text
best_model.pt filter=lfs diff=lfs merge=lfs -text
yolov7_plant_disease.torchscript.pt filter=lfs diff=lfs merge=lfs -text

# ONNX model files
*.onnx filter=lfs diff=lfs merge=lfs -text
yolov7_plant_disease.onnx filter=lfs diff=lfs merge=lfs -text

# Any pt files in checkpoints directory
checkpoints/*.pt filter=lfs diff=lfs merge=lfs -text
checkpoints/*.onnx filter=lfs diff=lfs merge=lfs -text
